# ── Sistema ──────────────────────────────────────────────────
AIRFLOW_UID=50000

# ── Airflow: Base de datos interna ───────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secret_password
AIRFLOW_DB_NAME=airflow

# ── Airflow: Seguridad ────────────────────────────────────────
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# ── Airflow: Usuario administrador ───────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_password
AIRFLOW_ADMIN_EMAIL=admin@datamart.com

# ── Data Warehouse analítico ──────────────────────────────────
DW_DB_USER=datamart
DW_DB_PASSWORD=datamart_secret_password
DW_DB_NAME=datamart_dw